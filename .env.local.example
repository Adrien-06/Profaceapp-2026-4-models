# Email Automation Configuration
# These variables are required for the free signup credit and email campaigns

# Resend API Key (for sending emails)
# Get it from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron Job Secret (for securing the email campaigns endpoint)
# Generate a strong random token (e.g., openssl rand -hex 32)
CRON_SECRET=your_random_secret_token_here

# The cron job runs every hour to send pending email campaigns:
# - Welcome email: sent immediately on signup
# - Day 3 email: sent 3 days after signup
# - Day 7 email: sent 7 days after signup

# Each email campaign includes:
# - A link back to the app with pre-filled auth
# - Personalized greeting with user's name
# - Clear CTA to use the free photo or upgrade
